{
  "name": "portfolio-v3-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "synth": "cdk synth",
    "diff": "cdk diff",
    "deploy:test": "cdk deploy --all --context stage=test --require-approval never --express",
    "deploy:prod": "cdk deploy --all --context stage=prod --require-approval broadening",
    "deploy:frontend:test": "cdk deploy FrontendStack-test --context stage=test --require-approval never --express",
    "deploy:frontend:prod": "cdk deploy FrontendStack-prod --context stage=prod --require-approval broadening",
    "destroy:test": "cdk destroy --all --context stage=test --force",
    "destroy:prod": "cdk destroy --all --context stage=prod --force",
    "test": "jest"
  },
  "dependencies": {
    "@aws-cdk/aws-lambda-go-alpha": "^2.260.0-alpha.0",
    "@aws-cdk/aws-pipes-alpha": "^2.260.0-alpha.0",
    "@aws-cdk/aws-pipes-sources-alpha": "^2.260.0-alpha.0",
    "@aws-cdk/aws-pipes-targets-alpha": "^2.260.0-alpha.0",
    "aws-cdk-lib": "2.260.0",
    "constructs": "10.6.0",
    "source-map-support": "0.5.21"
  },
  "devDependencies": {
    "@types/node": "22.15.32",
    "aws-cdk": "^2.1129.0",
    "ts-node": "10.9.2",
    "typescript": "5.8.3"
  }
}
